{
  "functions": {
    "source": "functions",
    "runtime": "python312",
    "codebase": "default",
    "ignore": [
      "venv",
      "__pycache__",
      ".pytest_cache",
      "tests"
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "emulators": {
    "auth": { "port": 9099 },
    "functions": { "port": 5001 },
    "firestore": { "port": 8080 },
    "ui": { "enabled": true, "port": 4000 }
  }
}
